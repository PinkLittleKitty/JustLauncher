<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             xmlns:loc="clr-namespace:JustLauncher.Resources"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="350"
             x:Class="JustLauncher.AboutDialog"
             Width="400">
    
    <Border Background="{DynamicResource ContentBackground}" 
            CornerRadius="16" 
            BorderBrush="{DynamicResource BorderBrush}" 
            BorderThickness="1"
            BoxShadow="0 8 24 0 #40000000"
            Margin="20">
        <Grid RowDefinitions="Auto,*,Auto" Margin="32">
            <!-- Header -->
            <Button x:Name="CloseButton" Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Top" Classes="Secondary" Padding="8" Margin="0,-8,-16,0">
                <i:Icon Value="fa-solid fa-times" FontSize="18"/>
            </Button>

            <!-- Content -->
            <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="24">
                <Grid HorizontalAlignment="Center">
                    <Border Background="{DynamicResource SuccessBrush}" Opacity="0.1" CornerRadius="20" Width="100" Height="100" />
                    <Image Source="/Assets/JustLogo.png" Width="80" Height="80" />
                </Grid>

                <StackPanel Spacing="4">
                    <TextBlock Text="{loc:Localize Key=About_Title}" Classes="PageHeader"/>
                    <TextBlock x:Name="VersionText" Classes="PageDescription"/>
                </StackPanel>

                <TextBlock Text="{loc:Localize Key=About_Description}" 
                           FontSize="13" Foreground="{DynamicResource SecondaryText}" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Opacity="0.7"/>
                
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                    <i:Icon Value="fa-solid fa-code" FontSize="14" Foreground="{DynamicResource SuccessBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="{loc:Localize Key=About_CreatedBy}" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Social Links -->
                <WrapPanel HorizontalAlignment="Center" Margin="0,8,0,0">
                    <Button x:Name="GitHubButton" Classes="Secondary" Padding="12,8" Margin="4" CornerRadius="8" ToolTip.Tip="View on GitHub">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <i:Icon Value="fa-brands fa-github" FontSize="16"/>
                            <TextBlock Text="{loc:Localize Key=About_GitHub}" FontSize="12" FontWeight="Medium"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="WebsiteButton" Classes="Secondary" Padding="12,8" Margin="4" CornerRadius="8" ToolTip.Tip="Visit Website">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <i:Icon Value="fa-solid fa-globe" FontSize="16"/>
                            <TextBlock Text="{loc:Localize Key=About_Website}" FontSize="12" FontWeight="Medium"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="ChangelogButton" Classes="Secondary" Padding="12,8" Margin="4" CornerRadius="8" ToolTip.Tip="View Changelog">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <i:Icon Value="fa-solid fa-list-ul" FontSize="16"/>
                            <TextBlock Text="{loc:Localize Key=Update_ViewChangelog}" FontSize="12" FontWeight="Medium"/>
                        </StackPanel>
                    </Button>
                </WrapPanel>
            </StackPanel>

            <!-- Footer -->
            <StackPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,24,0,0">
                <TextBlock Text="{Binding Copyright}" FontSize="11" Foreground="{DynamicResource SecondaryText}" Opacity="0.5"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
