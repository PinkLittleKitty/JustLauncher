<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:JustLauncher"
             x:Class="JustLauncher.PlayPage"
             Background="#23272A">
    <Grid Margin="20" RowDefinitions="Auto,*,Auto">
        <StackPanel Grid.Row="0" Spacing="5" Margin="0,0,0,20">
            <TextBlock Text="Installations" FontSize="24" Foreground="White" FontWeight="Bold"/>
            <TextBlock x:Name="JavaVersionText" Text="Java: Checking..." Foreground="Gray" FontSize="12"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1">
            <ItemsControl x:Name="InstallationsPanel">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#2C2F33" Margin="0,0,0,10" Padding="15" CornerRadius="8" BorderBrush="#404040" BorderThickness="1">
                            <Grid ColumnDefinitions="64,*,Auto">
                                <!-- Icon Placeholder -->
                                <Border Grid.Column="0" Width="48" Height="48" Background="#4CAF50" CornerRadius="4">
                                    <TextBlock Text="📦" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="15,0">
                                    <TextBlock Text="{Binding Name}" FontSize="18" Foreground="White" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding Version}" FontSize="14" Foreground="Gray"/>
                                </StackPanel>

                                <Button Grid.Column="2" Content="Play" VerticalAlignment="Center" Padding="20,10" Classes="Primary"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Margin="0,10,0,0">
            <ProgressBar x:Name="ProgressBar" Height="4" IsVisible="False" Margin="0,0,0,10"/>
            <Button x:Name="DownloadJavaButton" Content="Download Java" IsVisible="False" HorizontalAlignment="Right"/>
        </StackPanel>
    </Grid>
</UserControl>
