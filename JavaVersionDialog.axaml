<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="JustLauncher.JavaVersionDialog"
        Title="Java Version Mismatch"
        Width="500"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{DynamicResource WindowBackground}"
    Margin="0,0,0,20">
    <Border Padding="30">
        <StackPanel Spacing="20">
            <!-- Warning Icon and Title -->
            <StackPanel Orientation="Horizontal" Spacing="15">
                <TextBlock Text="⚠️" FontSize="32"/>
                <TextBlock Text="Java Version Mismatch" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Message -->
            <TextBlock x:Name="MessageText" 
                       TextWrapping="Wrap" 
                       Foreground="{DynamicResource SecondaryText}" 
                       FontSize="14"
                       LineHeight="22"/>

            <!-- Version Info -->
            <Border Background="{DynamicResource ContentBackground}" CornerRadius="8" Padding="15">
                <StackPanel Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="Required:" Foreground="{DynamicResource SecondaryText}" Width="100"/>
                        <TextBlock x:Name="RequiredVersionText" Foreground="{DynamicResource SuccessBrush}" FontWeight="Bold"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="Detected:" Foreground="{DynamicResource SecondaryText}" Width="100"/>
                        <TextBlock x:Name="DetectedVersionText" Foreground="#FF6B6B" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Warning -->
            <TextBlock Text="⚠️ The game will likely fail to start with the current Java version."
                       Foreground="#FFA500"
                       FontSize="13"
                       TextWrapping="Wrap"/>

            <!-- Buttons -->
            <Grid ColumnDefinitions="*,10,*" Margin="0,10,0,0">
                <Button x:Name="DownloadButton" 
                        Grid.Column="0"
                        Content="Download Java"
                        Classes="Primary"
                        Height="40"
                        FontSize="14"/>
                <Button x:Name="LaunchAnywayButton" 
                        Grid.Column="2"
                        Content="Launch Anyway"
                        Height="40"
                        FontSize="14"
                        Background="#5865F2"
                        Foreground="White"/>
            </Grid>
        </StackPanel>
    </Border>
</Window>
