<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:JustLauncher"
             x:Class="JustLauncher.AccountsPage"
             Background="#23272A">
    
    <Grid Margin="20" RowDefinitions="Auto,*,Auto">
        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,20">
            <StackPanel Grid.Column="0">
                <TextBlock Text="Account Management" FontSize="24" Foreground="White" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBlock Text="Manage your Minecraft accounts" FontSize="14" Foreground="Gray"/>
            </StackPanel>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                <Button x:Name="AddAccountButton" Content="+ Add Account" Classes="Primary"/>
                <Button x:Name="RefreshButton" Content="🔄 Refresh"/>
            </StackPanel>
        </Grid>

        <!-- Accounts List -->
        <ScrollViewer Grid.Row="1">
            <ItemsControl x:Name="AccountsPanel">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#2C2F33" Margin="0,0,0,12" CornerRadius="10" Padding="20"
                                BorderBrush="#404040" BorderThickness="1">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <!-- Account Icon -->
                                <StackPanel Grid.Column="0" Margin="0,0,20,0" Spacing="8">
                                    <Border Width="56" Height="56" Background="#4CAF50" CornerRadius="8">
                                        <TextBlock Text="{Binding AccountType, Converter={StaticResource AccountTypeToIconConverter}}" 
                                                   FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <Border Background="{Binding IsActive, Converter={StaticResource AccountBoolToColorConverter}}" 
                                            CornerRadius="10" Padding="6,2" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding IsActive, Converter={StaticResource AccountActiveStatusConverter}}" 
                                                   FontSize="10" FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                </StackPanel>
                                
                                <!-- Account Info -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                                    <TextBlock Text="{Binding Username}" FontSize="18" FontWeight="Bold" Foreground="White"/>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{Binding AccountType}" FontSize="13" Foreground="#00C851" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Email}" FontSize="11" Foreground="Gray"/>
                                    </StackPanel>
                                </StackPanel>
                                
                                <!-- Actions -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                                    <Button x:Name="UseAccountButton" Tag="{Binding}" Classes="Primary">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="✓"/>
                                            <TextBlock Text="Use Account"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="EditAccountButton" Content="✏️" Tag="{Binding}"/>
                                    <Button x:Name="DeleteAccountButton" Content="🗑️" Tag="{Binding}" Classes="Danger"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#1E2124" CornerRadius="6" Margin="0,10,0,0" Padding="15,10">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock x:Name="StatusText" Text="Ready" Foreground="Gray" FontSize="12"/>
                <TextBlock Text="•" Foreground="Gray" FontSize="12"/>
                <TextBlock x:Name="AccountCountText" Text="0 accounts" Foreground="Gray" FontSize="12"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
