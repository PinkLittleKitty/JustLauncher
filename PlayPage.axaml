<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="JustLauncher.PlayPage">
    
    <UserControl.Styles>
        <Style Selector="Button.HeroPlay">
            <Setter Property="Background" Value="#2da44e"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="40,15"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.HeroPlay:hover">
            <Setter Property="Background" Value="#2c974b"/>
            <Setter Property="RenderTransform" Value="scale(1.02)"/>
        </Style>
        <Style Selector="Button.HeroPlay:pressed">
            <Setter Property="RenderTransform" Value="scale(0.98)"/>
        </Style>
        
        <Style Selector="ComboBox.ProfileSelector">
            <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="MinHeight" Value="56"/>
        </Style>
    </UserControl.Styles>

    <Grid>
        <!-- Background Layer -->
        <Border>
            <Border.Background>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                    <GradientStop Offset="0" Color="#1E2124"/>
                    <GradientStop Offset="0.5" Color="#2C2F33"/>
                    <GradientStop Offset="1" Color="#23272A"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- Decorative "Minecraft" Background Element -->
        <Canvas Opacity="0.03" IsHitTestVisible="False">
            <TextBlock Text="MINECRAFT" FontSize="140" FontWeight="Black" Foreground="White" 
                       Canvas.Left="-50" Canvas.Top="50" />
            <TextBlock Text="MINECRAFT" FontSize="140" FontWeight="Black" Foreground="White" 
                       Canvas.Right="-50" Canvas.Bottom="100" />
        </Canvas>

        <!-- Main Content -->
        <Grid RowDefinitions="*,180">
            
            <!-- Hero Section -->
            <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="0">
                <i:Icon Value="fa-solid fa-gamepad" FontSize="140" Foreground="White" Opacity="0.05" HorizontalAlignment="Center" Margin="0,0,0,0">
                    <i:Icon.RenderTransform>
                        <TranslateTransform Y="40"/>
                    </i:Icon.RenderTransform>
                </i:Icon>
                <TextBlock x:Name="WelcomeText" Text="Welcome back, JustNeki!" FontSize="36" FontWeight="ExtraBold" Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="Ready for your next adventure?" FontSize="18" Foreground="{DynamicResource SecondaryText}" HorizontalAlignment="Center" Opacity="0.6" Margin="0,15,0,0"/>
            </StackPanel>

            <!-- Bottom Control Panel -->
            <Border Grid.Row="1" Background="{DynamicResource WindowBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="40,20">
                <Grid RowDefinitions="Auto,Auto">
                    
                    <!-- Progress Section -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,20">
                        <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <i:Icon Value="fa-solid fa-bolt" FontSize="14" Foreground="{DynamicResource SuccessBrush}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="StatusText" Text="Ready to Play" FontSize="14" Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center" FontWeight="Bold"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="JustLauncher 1.0.0" FontSize="12" Foreground="{DynamicResource SecondaryText}" VerticalAlignment="Center" Opacity="0.5"/>
                        </Grid>
                        <ProgressBar x:Name="ProgressBar" Height="4" IsVisible="False" IsIndeterminate="True" Foreground="{DynamicResource SuccessBrush}" Background="{DynamicResource ContentBackground}" CornerRadius="2"/>
                    </StackPanel>

                    <!-- Main Controls -->
                    <Grid Grid.Row="1" ColumnDefinitions="*,260" VerticalAlignment="Center">
                        <!-- Profile Selection -->
                        <StackPanel Grid.Column="0" Spacing="8" Margin="0,0,40,0">
                            <TextBlock Text="SELECTED INSTALLATION" FontSize="11" Foreground="{DynamicResource SecondaryText}" FontWeight="Bold" LetterSpacing="2"/>
                            <Grid ColumnDefinitions="*,Auto">
                                <ComboBox x:Name="ProfileComboBox" Classes="ProfileSelector" HorizontalAlignment="Stretch" VerticalContentAlignment="Center">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="Auto,*" Margin="2">
                                                <i:Icon Value="fa-solid fa-cube" Width="24" Height="24" FontSize="20" Foreground="{DynamicResource SuccessBrush}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource PrimaryText}"/>
                                                    <TextBlock Text="{Binding Version}" Foreground="{DynamicResource SecondaryText}" FontSize="12"/>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <Button x:Name="ManageProfilesButton" Grid.Column="1" Margin="12,0,0,0" Width="56" Height="56" Classes="Secondary">
                                    <i:Icon Value="fa-solid fa-gear" FontSize="20"/>
                                </Button>
                            </Grid>
                        </StackPanel>

                        <!-- Play Action -->
                        <Button Grid.Column="1" x:Name="PlayButton" Content="PLAY" Classes="Primary" HorizontalAlignment="Stretch" Height="56" FontSize="24" VerticalAlignment="Bottom"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
