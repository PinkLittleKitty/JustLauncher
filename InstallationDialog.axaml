<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             xmlns:loc="clr-namespace:JustLauncher.Resources"
             xmlns:controls="clr-namespace:JustLauncher.Controls"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="JustLauncher.InstallationDialog"
             Width="800">
    
    <Border Background="{DynamicResource ContentBackground}" 
            CornerRadius="16" 
            BorderBrush="{DynamicResource BorderBrush}" 
            BorderThickness="1"
            BoxShadow="0 8 24 0 #40000000"
            Margin="20">
        <Grid Margin="32" RowDefinitions="Auto,*,Auto">
            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,32" ColumnDefinitions="*,Auto">
                <StackPanel>
                    <TextBlock x:Name="DialogTitle" Text="{loc:Localize Key=Installation_Settings}" Classes="PageHeader" FontSize="24"/>
                    <TextBlock Text="{loc:Localize Key=Installation_ConfigureDescription}" Classes="PageDescription" FontSize="13"/>
                </StackPanel>
                <Button x:Name="CloseButton" Grid.Column="1" Classes="Secondary" Padding="8" VerticalAlignment="Top">
                    <i:Icon Value="fa-solid fa-times"/>
                </Button>
            </Grid>

            <!-- Form -->
            <!-- Form -->
            <TabControl Grid.Row="1" Margin="0,0,0,32">
                <TabItem Header="General" FontSize="16" Height="40">
                    <ScrollViewer Margin="0,20,0,0">
                        <Grid ColumnDefinitions="*,32,*">
                            <!-- Left Column -->
                            <StackPanel Grid.Column="0" Spacing="24">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="{loc:Localize Key=Installation_InstallationName}" Classes="PageDescription" FontSize="11" FontWeight="Bold" LetterSpacing="1"/>
                                    <TextBox x:Name="NameTextBox" Watermark="e.g. Latest Release" Padding="12"/>
                                </StackPanel>

                                <StackPanel Spacing="10">
                                    <TextBlock Text="{loc:Localize Key=Installation_MinecraftVersion}" Classes="PageDescription" FontSize="11" FontWeight="Bold" LetterSpacing="1"/>
                                    <ComboBox x:Name="VersionComboBox" HorizontalAlignment="Stretch"/>
                                </StackPanel>

                                <StackPanel Spacing="10">
                                    <TextBlock Text="{loc:Localize Key=Installation_ModLoader}" Classes="PageDescription" FontSize="11" FontWeight="Bold" LetterSpacing="1"/>
                                    <ComboBox x:Name="ModLoaderComboBox" HorizontalAlignment="Stretch">
                                        <ComboBoxItem Content="None" Tag="Vanilla"/>
                                        <ComboBoxItem Content="Fabric" Tag="Fabric"/>
                                        <ComboBoxItem Content="Forge" Tag="Forge"/>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel x:Name="ModLoaderVersionPanel" Spacing="10" IsVisible="False">
                                    <TextBlock Text="LOADER VERSION" Classes="PageDescription" FontSize="11" FontWeight="Bold" LetterSpacing="1"/>
                                    <ComboBox x:Name="ModLoaderVersionComboBox" HorizontalAlignment="Stretch"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Right Column -->
                            <StackPanel Grid.Column="2" Spacing="24">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="{loc:Localize Key=Installation_GameDirectory}" Classes="PageDescription" FontSize="11" FontWeight="Bold" LetterSpacing="1"/>
                                    <Grid ColumnDefinitions="*,8">
                                        <TextBox x:Name="GameDirectoryTextBox" Watermark="Default Directory" Padding="12"/>
                                        <Button x:Name="BrowseGameDirectoryButton" Grid.Column="1" Classes="Secondary" Padding="8" IsVisible="False">
                                            <i:Icon Value="fa-solid fa-folder-open"/>
                                        </Button>
                                    </Grid>
                                </StackPanel>

                                <StackPanel Spacing="10">
                                    <TextBlock Text="{loc:Localize Key=Installation_JvmArguments}" Classes="PageDescription" FontSize="11" FontWeight="Bold" LetterSpacing="1"/>
                                    <TextBox x:Name="JavaArgsTextBox" Text="-Xmx2G -Xms1G" Padding="12"/>
                                </StackPanel>

                                <StackPanel Spacing="10">
                                    <TextBlock Text="{loc:Localize Key=Installation_MemoryAllocation}" Classes="PageDescription" FontSize="11" FontWeight="Bold" LetterSpacing="1"/>
                                    <Border Background="{DynamicResource WindowBackground}" CornerRadius="12" Padding="20" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                        <StackPanel Spacing="12">
                                            <StackPanel Spacing="5">
                                                <TextBlock Text="{loc:Localize Key=Settings_JavaExecutablePath}" Foreground="{DynamicResource SecondaryText}" FontSize="12"/>
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <ComboBox x:Name="JavaVersionComboBox" HorizontalAlignment="Stretch" Margin="0,0,5,0" PlaceholderText="Use Global Setting"/>
                                                    <Button x:Name="BrowseJavaButton" Content="..." Width="30"/>
                                                </Grid>
                                            </StackPanel>

                                            <StackPanel Spacing="5">
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <TextBlock Text="{loc:Localize Key=Profile_MemoryAllocationGB}" Foreground="{DynamicResource SecondaryText}" FontSize="12"/>
                                                    <TextBlock x:Name="MemoryLabelValue" Text="4 GB" HorizontalAlignment="Right" Foreground="{DynamicResource AccentBrush}" FontSize="12"/>
                                                </Grid>
                                                
                                                <!-- Presets -->
                                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,5">
                                                    <Button x:Name="MemLowBtn" Content="2GB" Classes="Secondary" FontSize="10" Padding="6,2" CornerRadius="12"/>
                                                    <Button x:Name="MemMedBtn" Content="4GB" Classes="Secondary" FontSize="10" Padding="6,2" CornerRadius="12"/>
                                                    <Button x:Name="MemHighBtn" Content="8GB" Classes="Secondary" FontSize="10" Padding="6,2" CornerRadius="12"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <Slider x:Name="MemorySlider" Minimum="1" Maximum="32" Value="4" SmallChange="1" LargeChange="2"/>
                                            <TextBlock x:Name="MemoryLabel" Text="2 GB" Foreground="{DynamicResource SuccessBrush}" HorizontalAlignment="Center" FontWeight="Bold" FontSize="16"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </TabItem>
                <TabItem Header="Mods" x:Name="ModsTab" FontSize="16" IsEnabled="False">
                    <controls:ModsControl x:Name="ModsControl"/>
                </TabItem>
            </TabControl>

            <!-- Buttons -->
            <Grid Grid.Row="2">
                <Button x:Name="RemoveButton" Content="REMOVE" Classes="Danger" Padding="20,10" HorizontalAlignment="Left" IsVisible="False"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
                    <Button x:Name="CancelButton" Content="CANCEL" Classes="Secondary" MinWidth="100"/>
                    <Button x:Name="CreateButton" Content="SAVE INSTALLATION" Classes="Primary" MinWidth="180"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>
