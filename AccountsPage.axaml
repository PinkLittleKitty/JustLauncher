<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:JustLauncher"
             xmlns:converters="clr-namespace:JustLauncher.Converters"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             xmlns:controls="clr-namespace:JustLauncher.Controls"
             x:Class="JustLauncher.AccountsPage"
             Background="Transparent">
    
    <UserControl.Resources>
        <converters:AccountTypeToIconConverter x:Key="AccountTypeToIconConverter"/>
        <converters:SkinToBitmapConverter x:Key="SkinToBitmapConverter"/>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Button.CardAction">
            <Setter Property="Background" Value="#4A4A4A"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#222222"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="CornerRadius" Value="0"/>
        </Style>
        <Style Selector="Button.CardAction:hover">
            <Setter Property="Background" Value="#5A5A5A"/>
            <Setter Property="BorderBrush" Value="#8E9297"/>
        </Style>
        
        <Style Selector="Button.MCPrimary">
            <Setter Property="Background" Value="#3C8527"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#1E4314"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="0"/>
        </Style>
        <Style Selector="Button.MCPrimary:hover">
            <Setter Property="Background" Value="#47A02E"/>
            <Setter Property="BorderBrush" Value="#FFFFFF"/>
        </Style>

        <Style Selector="Border.AccountCard">
            <Setter Property="Background" Value="#313131"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,0,20,20"/>
            <Setter Property="Width" Value="240"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#1E1E1E"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.1"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.AccountCard:pointerover">
            <Setter Property="BorderBrush" Value="#FFFFFF"/>
            <Setter Property="RenderTransform" Value="translateY(-2px)"/>
        </Style>
    </UserControl.Styles>

    <Grid Margin="30" RowDefinitions="Auto,*,Auto">
        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,30">
            <StackPanel Grid.Column="0">
                <TextBlock Text="ACCOUNTS" FontSize="32" Foreground="White" FontWeight="Black" Margin="0,0,0,5"/>
                <TextBlock Text="Manage your player profiles" FontSize="14" Foreground="#8E9297"/>
            </StackPanel>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <Button x:Name="RefreshButton" ToolTip.Tip="Refresh" Padding="12" Background="#4A4A4A" CornerRadius="0">
                    <i:Icon Value="fa-solid fa-sync" Foreground="White"/>
                </Button>
                <Button x:Name="AddAccountButton" Classes="MCPrimary" Padding="15,10">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <i:Icon Value="fa-solid fa-plus"/>
                        <TextBlock Text="ADD ACCOUNT" FontWeight="Bold"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Accounts Grid -->
        <ScrollViewer Grid.Row="1">
            <ItemsControl x:Name="AccountsPanel">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Classes="AccountCard">
                            <StackPanel Spacing="15">
                                <!-- Avatar & Status -->
                                <Grid HorizontalAlignment="Center">
                                    <Border Width="96" Height="96" BorderBrush="#1E1E1E" BorderThickness="4">
                                        <Panel>
                                            <controls:AsyncImage SourceUrl="{Binding Username, StringFormat='https://minotar.net/avatar/{0}/64'}"
                                                   Stretch="UniformToFill"
                                                   RenderOptions.BitmapInterpolationMode="None"/>
                                            <!-- Overlay for active status -->
                                            <Border IsVisible="{Binding IsActive}" 
                                                    BorderBrush="#3C8527" BorderThickness="4" 
                                                    Margin="-4"/>
                                        </Panel>
                                    </Border>
                                    
                                    <Border IsVisible="{Binding IsActive}"
                                            Background="#3C8527" Padding="8,4"
                                            VerticalAlignment="Top" HorizontalAlignment="Right"
                                            Margin="0,-10,-10,0">
                                        <TextBlock Text="ACTIVE" FontSize="10" FontWeight="Black" Foreground="White"/>
                                    </Border>
                                </Grid>

                                <!-- Info -->
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding Username}" FontSize="18" FontWeight="Bold" Foreground="White" 
                                               HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding AccountType}" FontSize="11" Foreground="#8E9297" 
                                               HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>

                                <!-- Divider -->
                                <Border Height="2" Background="#1E1E1E" Margin="0,5"/>

                                <!-- Actions -->
                                <StackPanel Spacing="10">
                                    <Button x:Name="UseAccountButton" Tag="{Binding}" Classes="MCPrimary" 
                                            HorizontalAlignment="Stretch" Padding="0,8">
                                         <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                            <i:Icon Value="{Binding IsActive, Converter={StaticResource AccountTypeToIconConverter}, ConverterParameter='active_icon'}"/>
                                            <TextBlock Text="{Binding IsActive, Converter={StaticResource AccountTypeToIconConverter}, ConverterParameter='active_text'}" FontWeight="Bold"/>
                                        </StackPanel>   
                                    </Button>
                                    
                                    <Grid ColumnDefinitions="*,10,*">
                                        <Button Grid.Column="0" x:Name="EditAccountButton" Tag="{Binding}" Classes="CardAction">
                                            <i:Icon Value="fa-solid fa-pen"/>
                                        </Button>
                                        <Button Grid.Column="2" x:Name="DeleteAccountButton" Tag="{Binding}" Classes="CardAction" Foreground="#ED4245">
                                            <i:Icon Value="fa-solid fa-trash"/>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="2" Padding="0,20,0,0" BorderBrush="#2C2F33" BorderThickness="0,1,0,0">
            <TextBlock x:Name="AccountCountText" Text="0 Accounts Connected" Foreground="#8E9297" FontSize="12"/>
        </Border>
    </Grid>
</UserControl>
