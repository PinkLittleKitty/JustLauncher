<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:JustLauncher"
             xmlns:converters="clr-namespace:JustLauncher.Converters"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             xmlns:controls="clr-namespace:JustLauncher.Controls"
             xmlns:loc="clr-namespace:JustLauncher.Resources"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="JustLauncher.AccountsPage"
             Background="Transparent">
    
    <UserControl.Resources>
        <converters:AccountTypeToIconConverter x:Key="AccountTypeToIconConverter"/>
        <converters:SkinToBitmapConverter x:Key="SkinToBitmapConverter"/>
        <converters:AccountToSkinUrlConverter x:Key="AccountToSkinUrlConverter"/>
        <converters:AccountToSourceRectConverter x:Key="AccountToSourceRectConverter"/>
    </UserControl.Resources>

    <Grid Margin="40" RowDefinitions="Auto,*,Auto">
        <!-- Action Buttons -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="16" HorizontalAlignment="Center" Margin="0,0,0,32">
            <Button x:Name="RefreshButton" ToolTip.Tip="Refresh" Padding="12" Classes="Secondary">
                <i:Icon Value="fa-solid fa-sync" FontSize="20"/>
            </Button>
            <Button x:Name="AddAccountButton" Classes="Primary" Padding="24,10">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <i:Icon Value="fa-solid fa-plus" FontSize="20"/>
                    <TextBlock Text="{loc:Localize Key=Accounts_AddAccount}" FontWeight="Bold"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- Accounts Grid -->
        <ScrollViewer Grid.Row="1">
            <ItemsControl x:Name="AccountsPanel">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Classes="Card" Margin="0,0,16,16" Padding="16" Width="220">
                            <StackPanel Spacing="20">
                                <!-- Avatar & Status -->
                                <Grid HorizontalAlignment="Center">
                                    <Border Width="80" Height="80" CornerRadius="0" ClipToBounds="True" 
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="3">
                                        <Panel>
                                            <controls:AsyncImage SourceUrl="{Binding Converter={StaticResource AccountToSkinUrlConverter}}"
                                                   SourceRect="{Binding Converter={StaticResource AccountToSourceRectConverter}}"
                                                   Stretch="UniformToFill"
                                                   RenderOptions.BitmapInterpolationMode="None"/>
                                            <!-- Overlay for active status -->
                                            <Border IsVisible="{Binding IsActive}" 
                                                    Background="{DynamicResource SuccessBrush}" Opacity="0.1"/>
                                        </Panel>
                                    </Border>
                                    
                                    <Border IsVisible="{Binding IsActive}"
                                            Background="{DynamicResource SuccessBrush}" CornerRadius="10" Padding="8,4"
                                            VerticalAlignment="Top" HorizontalAlignment="Right"
                                            Margin="0,-5,-5,0" Effect="drop-shadow(0 2 4 #40000000)">
                                        <TextBlock Text="{loc:Localize Key=Accounts_Active}" FontSize="10" FontWeight="Black" Foreground="White"/>
                                    </Border>
                                </Grid>

                                <!-- Info -->
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding Username}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource PrimaryText}" 
                                               HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding AccountType}" FontSize="12" Foreground="{DynamicResource SecondaryText}" 
                                               HorizontalAlignment="Center" FontWeight="SemiBold" Opacity="0.8"/>
                                </StackPanel>

                                <!-- Actions -->
                                <StackPanel Spacing="12">
                                    <Button x:Name="UseAccountButton" Tag="{Binding}" 
                                            Classes="Primary"
                                            IsVisible="{Binding !IsActive}"
                                            HorizontalAlignment="Stretch" Padding="0,10">
                                         <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                            <i:Icon Value="fa-solid fa-check"/>
                                            <TextBlock Text="{loc:Localize Key=Accounts_UseAccount}"/>
                                        </StackPanel>   
                                    </Button>
                                    
                                    <Grid ColumnDefinitions="*,12,*">
                                        <Button Grid.Column="0" x:Name="EditAccountButton" Tag="{Binding}" Classes="Secondary" HorizontalAlignment="Stretch">
                                            <i:Icon Value="fa-solid fa-pen"/>
                                        </Button>
                                        <Button Grid.Column="2" x:Name="DeleteAccountButton" Tag="{Binding}" Classes="Danger" HorizontalAlignment="Stretch">
                                            <i:Icon Value="fa-solid fa-trash"/>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="2" Padding="0,20,0,0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <TextBlock x:Name="AccountCountText" Text="0 Accounts Connected" Foreground="{DynamicResource SecondaryText}" FontSize="12"/>
        </Border>
    </Grid>
</UserControl>
