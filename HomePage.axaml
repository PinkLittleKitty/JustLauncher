<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             xmlns:loc="clr-namespace:JustLauncher.Resources"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="JustLauncher.HomePage">
    
    <Grid>
        <!-- Background -->
        <Border Background="{DynamicResource WindowBackground}"/>

        <!-- Step 1: Selection Cards -->
        <StackPanel x:Name="Step1Container" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="40">
            <StackPanel Spacing="12" HorizontalAlignment="Center">
                <Border Background="Transparent" Width="100" Height="100" HorizontalAlignment="Center">
                    <Image Source="/Assets/JustLogo.png" />
                </Border>
                <TextBlock Text="{loc:Localize Key=Home_SetupTitle}" Classes="PageHeader" HorizontalAlignment="Center"/>
                <TextBlock Text="{loc:Localize Key=Home_SetupDescription}" Classes="PageDescription" HorizontalAlignment="Center" Margin="0,0,0,32"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="24" HorizontalAlignment="Center">
                <Button x:Name="OfflineCard" Classes="Secondary" Padding="0" CornerRadius="20" Tag="Offline">
                    <Border Width="300" Height="380" Background="{DynamicResource ContentBackground}" CornerRadius="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                        <Grid RowDefinitions="*,Auto,Auto" Margin="32">
                            <i:Icon Value="fa-solid fa-user-slash" FontSize="64" Foreground="{DynamicResource SuccessBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="1" Text="{loc:Localize Key=Home_Offline}" FontSize="20" FontWeight="Black" Margin="0,0,0,8" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Row="2" Text="{loc:Localize Key=Home_OfflineDesc}" FontSize="13" Foreground="{DynamicResource SecondaryText}" TextWrapping="Wrap" TextAlignment="Center" Opacity="0.8"/>
                        </Grid>
                    </Border>
                </Button>

                <Button x:Name="ElyByCard" Classes="Secondary" Padding="0" CornerRadius="20" Tag="ElyBy">
                    <Border Width="300" Height="380" Background="{DynamicResource ContentBackground}" CornerRadius="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                        <Grid RowDefinitions="*,Auto,Auto" Margin="32">
                            <i:Icon Value="fa-solid fa-globe" FontSize="64" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="1" Text="{loc:Localize Key=Home_ElyBy}" FontSize="20" FontWeight="Black" Margin="0,0,0,8" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Row="2" Text="{loc:Localize Key=Home_ElyByDesc}" FontSize="13" Foreground="{DynamicResource SecondaryText}" TextWrapping="Wrap" TextAlignment="Center" Opacity="0.8"/>
                        </Grid>
                    </Border>
                </Button>

                <Button x:Name="MicrosoftCard" Classes="Secondary" Padding="0" CornerRadius="20" Tag="Microsoft">
                    <Border Width="300" Height="380" Background="{DynamicResource ContentBackground}" CornerRadius="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                        <Grid RowDefinitions="*,Auto,Auto" Margin="32">
                            <i:Icon Value="fa-brands fa-microsoft" FontSize="64" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="1" Text="{loc:Localize Key=Home_Microsoft}" FontSize="20" FontWeight="Black" Margin="0,0,0,8" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Row="2" Text="{loc:Localize Key=Home_MicrosoftDesc}" FontSize="13" Foreground="{DynamicResource SecondaryText}" TextWrapping="Wrap" TextAlignment="Center" Opacity="0.8"/>
                        </Grid>
                    </Border>
                </Button>
            </StackPanel>
        </StackPanel>

        <!-- Step 2: Input Overlay -->
        <Border x:Name="Step2Overlay" Background="#EE1E1E20" IsVisible="False">
            <Border Background="{DynamicResource ContentBackground}" CornerRadius="28" Padding="48" Width="450" HorizontalAlignment="Center" VerticalAlignment="Center" BoxShadow="0 24 64 0 #AA000000">
                <StackPanel Spacing="32">
                    <StackPanel Spacing="12">
                        <Border x:Name="Step2BackBtn" HorizontalAlignment="Left" Background="Transparent" Cursor="Hand">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <i:Icon Value="fa-solid fa-arrow-left" FontSize="14" Foreground="{DynamicResource SecondaryText}"/>
                                <TextBlock Text="{loc:Localize Key=Home_Back}" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource SecondaryText}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <TextBlock x:Name="Step2Header" Text="{loc:Localize Key=Home_EnterCredentials}" Classes="PageHeader" Margin="0,12,0,0"/>
                        <TextBlock x:Name="Step2Subheader" Text="{loc:Localize Key=Home_CredentialsDescription}" FontSize="14" Foreground="{DynamicResource SecondaryText}" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Spacing="24">
                        <StackPanel Spacing="10">
                            <TextBlock x:Name="FieldLabel" Text="{loc:Localize Key=AccountDialog_Username}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource SecondaryText}" LetterSpacing="1"/>
                            <TextBox x:Name="UsernameTextBox" Padding="16" CornerRadius="12" Watermark="{loc:Localize Key=Home_YourName}"/>
                        </StackPanel>

                        <StackPanel x:Name="PasswordContainer" Spacing="10" IsVisible="False">
                            <TextBlock Text="{loc:Localize Key=AccountDialog_Password}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource SecondaryText}" LetterSpacing="1"/>
                            <TextBox x:Name="PasswordTextBox" PasswordChar="*" Padding="16" CornerRadius="12" Watermark="{loc:Localize Key=Home_YourSecret}"/>
                        </StackPanel>
                    </StackPanel>

                    <Button x:Name="FinalLoginBtn" Content="{loc:Localize Key=Home_GetStarted}" Classes="Primary" Height="54" HorizontalAlignment="Stretch" FontSize="16" FontWeight="Bold" CornerRadius="16"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
