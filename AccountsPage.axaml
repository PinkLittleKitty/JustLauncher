<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:JustLauncher"
             xmlns:converters="clr-namespace:JustLauncher.Converters"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             x:Class="JustLauncher.AccountsPage"
             Background="Transparent">
    
    <UserControl.Resources>
        <converters:AccountTypeToIconConverter x:Key="AccountTypeToIconConverter"/>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Button.CardAction">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryText}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.CardAction:hover">
            <Setter Property="Background" Value="{DynamicResource HoverBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
        </Style>
        <Style Selector="Border.AccountCard">
            <Setter Property="Background" Value="{DynamicResource ContentBackground}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,0,15,15"/>
            <Setter Property="Width" Value="220"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.2"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.AccountCard:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="RenderTransform" Value="scale(1.02)"/>
        </Style>
    </UserControl.Styles>

    <Grid Margin="30" RowDefinitions="Auto,*,Auto">
        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,20">
            <StackPanel Grid.Column="0">
                <TextBlock Text="Accounts" FontSize="28" Foreground="{DynamicResource PrimaryText}" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBlock Text="Manage your Minecraft accounts" FontSize="14" Foreground="{DynamicResource SecondaryText}"/>
            </StackPanel>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <Button x:Name="RefreshButton" ToolTip.Tip="Refresh" Padding="10">
                    <i:Icon Value="fa-solid fa-sync"/>
                </Button>
                <Button x:Name="AddAccountButton" Classes="Primary">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <i:Icon Value="fa-solid fa-plus"/>
                        <TextBlock Text="Add Account"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Accounts Grid -->
        <ScrollViewer Grid.Row="1">
            <ItemsControl x:Name="AccountsPanel">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Classes="AccountCard">
                            <StackPanel Spacing="12">
                                <!-- Avatar & Status -->
                                <Grid>
                                    <Border Width="72" Height="72" Background="#DDDDDD" CornerRadius="36" ClipToBounds="True">
                                        <!-- Need a generic icon here for now, dynamic binding for type specific icons is tricky with Icon Value -->
                                        <!-- We can use a converter to return the icon string, or just use a generic 'user' for now -->
                                        <i:Icon Value="fa-solid fa-user" FontSize="36" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <Border Background="#4CAF50" Width="16" Height="16" CornerRadius="8" 
                                            HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,65,0"
                                            IsVisible="{Binding IsActive}" BorderBrush="{DynamicResource ContentBackground}" BorderThickness="2"/>
                                </Grid>

                                <!-- Info -->
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding Username}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource PrimaryText}" 
                                               HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding AccountType}" FontSize="12" Foreground="{DynamicResource SecondaryText}" 
                                               HorizontalAlignment="Center"/>
                                </StackPanel>

                                <!-- Divider -->
                                <Separator Height="1" Background="{DynamicResource BorderBrush}" Margin="0,5"/>

                                <!-- Actions -->
                                <StackPanel Spacing="8">
                                    <Button x:Name="UseAccountButton" Tag="{Binding}" Classes="Primary" HorizontalAlignment="Stretch" 
                                            IsEnabled="{Binding !IsActive}">
                                         <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                            <i:Icon Value="fa-solid fa-check"/>
                                            <TextBlock Text="Select"/>
                                        </StackPanel>   
                                    </Button>
                                    
                                    <Grid ColumnDefinitions="*,5,*">
                                        <Button Grid.Column="0" x:Name="EditAccountButton" Tag="{Binding}" Classes="CardAction">
                                            <StackPanel Orientation="Horizontal" Spacing="5">
                                                <i:Icon Value="fa-solid fa-pen"/>
                                                <TextBlock Text="Edit"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Grid.Column="2" x:Name="DeleteAccountButton" Tag="{Binding}" Classes="CardAction" Foreground="{DynamicResource DangerBrush}">
                                            <StackPanel Orientation="Horizontal" Spacing="5">
                                                <i:Icon Value="fa-solid fa-trash"/>
                                                <TextBlock Text="Remove"/>
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
