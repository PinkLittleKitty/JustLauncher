<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="400"
             x:Class="JustLauncher.AccountDialog"
             Width="500">
    
    <Border Background="{DynamicResource ContentBackground}" 
            CornerRadius="16" 
            BorderBrush="{DynamicResource BorderBrush}" 
            BorderThickness="1"
            BoxShadow="0 8 24 0 #40000000"
            Margin="20">
        <Grid Margin="32" RowDefinitions="Auto,*,Auto">
            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,32" ColumnDefinitions="*,Auto">
                <StackPanel>
                    <TextBlock x:Name="DialogTitle" Text="Add New Account" Classes="PageHeader" FontSize="24"/>
                    <TextBlock Text="Configure your Minecraft account settings" Classes="PageDescription" FontSize="13"/>
                </StackPanel>
                <Button x:Name="CloseButton" Grid.Column="1" Classes="Secondary" Padding="8" VerticalAlignment="Top">
                    <i:Icon Value="fa-solid fa-times"/>
                </Button>
            </Grid>

            <!-- Form -->
            <StackPanel Grid.Row="1" Spacing="24">
                <StackPanel Spacing="10">
                    <TextBlock Text="USERNAME" Foreground="{DynamicResource SecondaryText}" FontSize="11" FontWeight="Bold" LetterSpacing="1"/>
                    <TextBox x:Name="UsernameTextBox" Watermark="e.g. JustNeki" Padding="12"/>
                </StackPanel>

                <StackPanel Spacing="10">
                    <TextBlock Text="ACCOUNT TYPE" Foreground="{DynamicResource SecondaryText}" FontSize="11" FontWeight="Bold" LetterSpacing="1"/>
                    <ComboBox x:Name="AccountTypeComboBox" HorizontalAlignment="Stretch" SelectedIndex="0">
                        <ComboBoxItem Content="Offline Account" Tag="Offline"/>
                        <ComboBoxItem Content="Microsoft Account" Tag="Microsoft" IsEnabled="False"/>
                        <ComboBoxItem Content="Mojang Account" Tag="Mojang" IsEnabled="False"/>
                    </ComboBox>
                </StackPanel>

                <!-- Info Panel -->
                <Border Background="{DynamicResource WindowBackground}" CornerRadius="12" Padding="20" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <i:Icon Value="fa-solid fa-info-circle" Foreground="{DynamicResource SuccessBrush}"/>
                            <TextBlock x:Name="InfoTitle" Text="Offline Account" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}"/>
                        </StackPanel>
                        <TextBlock x:Name="InfoText" Text="Offline accounts allow you to play Minecraft without authentication. You can use any username you want." 
                                   FontSize="12" Foreground="{DynamicResource SecondaryText}" TextWrapping="Wrap" Opacity="0.8"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12" Margin="0,32,0,0">
                <Button x:Name="CancelButton" Content="CANCEL" Classes="Secondary" MinWidth="100"/>
                <Button x:Name="SaveButton" Content="SAVE ACCOUNT" Classes="Primary" MinWidth="140"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
