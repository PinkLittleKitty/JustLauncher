<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="JustLauncher.InstallationDialog"
        Title="New Installation" Height="650" Width="700"
        WindowStartupLocation="CenterOwner"
        SystemDecorations="None"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1"
        Background="#23272A">
    
    <Grid Margin="30" RowDefinitions="Auto,*,Auto">
        <!-- Header -->
        <Grid Grid.Row="0" x:Name="DialogHeader" Margin="0,0,0,30" ColumnDefinitions="*,Auto" Background="Transparent">
            <StackPanel>
                <TextBlock x:Name="DialogTitle" Text="Create New Installation" FontSize="24" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="Configure your Minecraft installation settings" FontSize="14" Foreground="Gray" Margin="0,5,0,0"/>
            </StackPanel>
            <Button x:Name="CloseButton" Grid.Column="1" Content="✕" Background="Transparent" Foreground="#999" Padding="10"/>
        </Grid>

        <!-- Form -->
        <ScrollViewer Grid.Row="1" Margin="0,0,0,20">
            <Grid ColumnDefinitions="*,20,*">
                <!-- Left Column -->
                <StackPanel Grid.Column="0" Spacing="20">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Installation Name" Foreground="White" FontWeight="SemiBold"/>
                        <TextBox x:Name="NameTextBox"/>
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="Minecraft Version" Foreground="White" FontWeight="SemiBold"/>
                        <ComboBox x:Name="VersionComboBox" HorizontalAlignment="Stretch"/>
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="Mod Loader" Foreground="White" FontWeight="SemiBold"/>
                        <ComboBox x:Name="ModLoaderComboBox" HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="None" Tag="none" IsSelected="True"/>
                            <ComboBoxItem Content="Fabric" Tag="fabric"/>
                            <ComboBoxItem Content="Forge" Tag="forge"/>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>

                <!-- Right Column -->
                <StackPanel Grid.Column="2" Spacing="20">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Game Directory" Foreground="White" FontWeight="SemiBold"/>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox x:Name="GameDirectoryTextBox"/>
                            <Button x:Name="BrowseGameDirectoryButton" Grid.Column="1" Content="📁" Margin="5,0,0,0"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="JVM Arguments" Foreground="White" FontWeight="SemiBold"/>
                        <TextBox x:Name="JavaArgsTextBox" Text="-Xmx2G -Xms1G"/>
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="Memory Allocation" Foreground="White" FontWeight="SemiBold"/>
                        <Slider x:Name="MemorySlider" Minimum="1" Maximum="16" Value="2" SmallChange="1" LargeChange="2"/>
                        <TextBlock x:Name="MemoryLabel" Text="2 GB" Foreground="#00C851" HorizontalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
            <Button x:Name="CancelButton" Content="Cancel" Padding="25,10"/>
            <Button x:Name="CreateButton" Content="Create Installation" Classes="Primary" Padding="25,10"/>
        </StackPanel>
    </Grid>
</Window>
