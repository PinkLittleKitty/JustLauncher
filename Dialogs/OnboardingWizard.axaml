<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="https://github.com/projektanker/icons.avalonia"
        xmlns:loc="clr-namespace:JustLauncher.Resources"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
        x:Class="JustLauncher.Dialogs.OnboardingWizard"
        Title="{loc:Localize Onboarding_Welcome_Title}"
        Width="1000" Height="700"
        WindowStartupLocation="CenterScreen"
        SystemDecorations="None"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1"
        Background="{DynamicResource WindowBackground}"
        CanResize="False">

    <Grid RowDefinitions="32,Auto,*,Auto">
        <!-- Dragging Area -->
        <Grid Grid.Row="0" x:Name="TitleBar" Background="Transparent"/>

        <!-- Progress Bar Header -->
        <Border Grid.Row="1" Background="{DynamicResource TitleBarBackground}" Padding="40,24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="8">
                    <TextBlock x:Name="ProgressText" Text="Step 1 of 5" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource SecondaryText}" LetterSpacing="2"/>
                    <ProgressBar x:Name="ProgressBar" Height="4" Value="20" Maximum="100" Foreground="{DynamicResource SuccessBrush}" Background="{DynamicResource ContentBackground}" CornerRadius="2"/>
                </StackPanel>
                
                <Button Grid.Column="1" x:Name="SkipButton" Content="{loc:Localize Onboarding_Skip}" Classes="Secondary" Padding="16,8" FontSize="12"/>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Panel>
            <!-- Step 1: Welcome Screen -->
            <Grid x:Name="Step1" Margin="60">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="48">
                    <!-- Logo with animation -->
                    <Border Width="160" Height="160" HorizontalAlignment="Center">
                        <Image Source="/Assets/JustLogo.png" RenderOptions.BitmapInterpolationMode="HighQuality"/>
                    </Border>
                    
                    <StackPanel Spacing="16" HorizontalAlignment="Center">
                        <TextBlock Text="{loc:Localize Onboarding_Welcome_Title}" FontSize="48" FontWeight="Black" Foreground="{DynamicResource PrimaryText}" HorizontalAlignment="Center" LetterSpacing="1"/>
                        <TextBlock Text="{loc:Localize Onboarding_Welcome_Subtitle}" FontSize="20" Foreground="{DynamicResource SecondaryText}" HorizontalAlignment="Center" Opacity="0.8"/>
                    </StackPanel>
                    
                    <!-- Feature Showcase -->
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" HorizontalAlignment="Center" Margin="0,32,0,0">
                        <StackPanel Grid.Column="0" Grid.Row="0" Orientation="Horizontal" Spacing="16" Margin="0,0,20,12">
                            <i:Icon Value="fa-solid fa-bolt" FontSize="24" Foreground="{DynamicResource SuccessBrush}" VerticalAlignment="Center"/>
                            <StackPanel Spacing="4">
                                <TextBlock Text="{loc:Localize Onboarding_Welcome_Feature1_Title}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource PrimaryText}"/>
                                <TextBlock Text="{loc:Localize Onboarding_Welcome_Feature1_Desc}" FontSize="13" Foreground="{DynamicResource SecondaryText}" Opacity="0.7"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1" Grid.Row="0" Orientation="Horizontal" Spacing="16" Margin="20,0,0,12">
                            <i:Icon Value="fa-solid fa-puzzle-piece" FontSize="24" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                            <StackPanel Spacing="4">
                                <TextBlock Text="{loc:Localize Onboarding_Welcome_Feature2_Title}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource PrimaryText}"/>
                                <TextBlock Text="{loc:Localize Onboarding_Welcome_Feature2_Desc}" FontSize="13" Foreground="{DynamicResource SecondaryText}" Opacity="0.7"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="0" Grid.Row="1" Orientation="Horizontal" Spacing="16" Margin="0,12,20,0">
                            <i:Icon Value="fa-solid fa-users" FontSize="24" Foreground="{DynamicResource WarningBrush}" VerticalAlignment="Center"/>
                            <StackPanel Spacing="4">
                                <TextBlock Text="{loc:Localize Onboarding_Welcome_Feature3_Title}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource PrimaryText}"/>
                                <TextBlock Text="{loc:Localize Onboarding_Welcome_Feature3_Desc}" FontSize="13" Foreground="{DynamicResource SecondaryText}" Opacity="0.7"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1" Grid.Row="1" Orientation="Horizontal" Spacing="16" Margin="20,12,0,0">
                            <i:Icon Value="fa-solid fa-palette" FontSize="24" Foreground="{DynamicResource ErrorBrush}" VerticalAlignment="Center"/>
                            <StackPanel Spacing="4">
                                <TextBlock Text="{loc:Localize Onboarding_Welcome_Feature4_Title}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource PrimaryText}"/>
                                <TextBlock Text="{loc:Localize Onboarding_Welcome_Feature4_Desc}" FontSize="13" Foreground="{DynamicResource SecondaryText}" Opacity="0.7"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Grid>

            <!-- Step 2: Account Setup -->
            <Grid x:Name="Step2" IsVisible="False" Margin="60">
                <StackPanel VerticalAlignment="Center" Spacing="40">
                    <StackPanel Spacing="12" HorizontalAlignment="Center">
                        <TextBlock Text="{loc:Localize Onboarding_Account_Title}" FontSize="36" FontWeight="Black" Foreground="{DynamicResource PrimaryText}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{loc:Localize Onboarding_Account_Subtitle}" FontSize="16" Foreground="{DynamicResource SecondaryText}" HorizontalAlignment="Center" Opacity="0.8"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" Spacing="24" HorizontalAlignment="Center">
                        <!-- Offline Card -->
                        <Button x:Name="OfflineAccountCard" Classes="Secondary" Padding="0" CornerRadius="16" Tag="Offline">
                            <Border Width="280" Height="420" Background="{DynamicResource ContentBackground}" CornerRadius="16" BorderBrush="{DynamicResource SuccessBrush}" BorderThickness="2">
                                <Grid RowDefinitions="Auto,*,Auto,Auto" Margin="28">
                                    <Border Grid.Row="0" Background="{DynamicResource SuccessBrush}" CornerRadius="8" Padding="10,6" HorizontalAlignment="Center">
                                        <TextBlock Text="{loc:Localize Onboarding_Account_Recommended}" FontSize="10" FontWeight="Black" Foreground="White" LetterSpacing="1"/>
                                    </Border>
                                    
                                    <i:Icon Grid.Row="1" Value="fa-solid fa-user" FontSize="72" Foreground="{DynamicResource SuccessBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    
                                    <StackPanel Grid.Row="2" Spacing="12">
                                        <TextBlock Text="{loc:Localize Onboarding_Account_Offline_Title}" FontSize="22" FontWeight="Black" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{loc:Localize Onboarding_Account_Offline_Desc}" FontSize="13" Foreground="{DynamicResource SecondaryText}" TextWrapping="Wrap" TextAlignment="Center" Opacity="0.8"/>
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Row="3" Spacing="8" Margin="0,20,0,0">
                                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                            <i:Icon Value="fa-solid fa-check" FontSize="12" Foreground="{DynamicResource SuccessBrush}"/>
                                            <TextBlock Text="{loc:Localize Onboarding_Account_Offline_Feature1}" FontSize="12" Foreground="{DynamicResource SecondaryText}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                            <i:Icon Value="fa-solid fa-check" FontSize="12" Foreground="{DynamicResource SuccessBrush}"/>
                                            <TextBlock Text="{loc:Localize Onboarding_Account_Offline_Feature2}" FontSize="12" Foreground="{DynamicResource SecondaryText}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                            <i:Icon Value="fa-solid fa-check" FontSize="12" Foreground="{DynamicResource SuccessBrush}"/>
                                            <TextBlock Text="{loc:Localize Onboarding_Account_Offline_Feature3}" FontSize="12" Foreground="{DynamicResource SecondaryText}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Button>
                        
                        <!-- Ely.by Card -->
                        <Button x:Name="ElyByAccountCard" Classes="Secondary" Padding="0" CornerRadius="16" Tag="ElyBy">
                            <Border Width="280" Height="420" Background="{DynamicResource ContentBackground}" CornerRadius="16" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <Grid RowDefinitions="Auto,*,Auto,Auto" Margin="28">
                                    <Border Grid.Row="0" Height="28"/>
                                    
                                    <i:Icon Grid.Row="1" Value="fa-solid fa-globe" FontSize="72" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    
                                    <StackPanel Grid.Row="2" Spacing="12">
                                        <TextBlock Text="{loc:Localize Onboarding_Account_ElyBy_Title}" FontSize="22" FontWeight="Black" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{loc:Localize Onboarding_Account_ElyBy_Desc}" FontSize="13" Foreground="{DynamicResource SecondaryText}" TextWrapping="Wrap" TextAlignment="Center" Opacity="0.8"/>
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Row="3" Spacing="8" Margin="0,20,0,0">
                                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                            <i:Icon Value="fa-solid fa-check" FontSize="12" Foreground="{DynamicResource AccentBrush}"/>
                                            <TextBlock Text="{loc:Localize Onboarding_Account_ElyBy_Feature1}" FontSize="12" Foreground="{DynamicResource SecondaryText}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                            <i:Icon Value="fa-solid fa-check" FontSize="12" Foreground="{DynamicResource AccentBrush}"/>
                                            <TextBlock Text="{loc:Localize Onboarding_Account_ElyBy_Feature2}" FontSize="12" Foreground="{DynamicResource SecondaryText}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Button>
                        
                        <!-- Microsoft Card (Coming Soon) -->
                        <Border Width="280" Height="420" Background="{DynamicResource WindowBackground}" CornerRadius="16" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Opacity="0.5">
                            <Grid RowDefinitions="Auto,*,Auto,Auto" Margin="28">
                                <Border Grid.Row="0" Background="{DynamicResource SecondaryText}" CornerRadius="8" Padding="10,6" HorizontalAlignment="Center">
                                    <TextBlock Text="{loc:Localize Onboarding_Account_Microsoft_ComingSoon}" FontSize="10" FontWeight="Black" Foreground="White" LetterSpacing="1"/>
                                </Border>
                                
                                <i:Icon Grid.Row="1" Value="fa-brands fa-microsoft" FontSize="72" Foreground="{DynamicResource SecondaryText}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                
                                <StackPanel Grid.Row="2" Spacing="12">
                                    <TextBlock Text="{loc:Localize Onboarding_Account_Microsoft_Title}" FontSize="22" FontWeight="Black" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{loc:Localize Onboarding_Account_Microsoft_Desc}" FontSize="13" Foreground="{DynamicResource SecondaryText}" TextWrapping="Wrap" TextAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- Step 3: Java Detection (Placeholder) -->
            <Grid x:Name="Step3" IsVisible="False" Margin="60">
                <StackPanel VerticalAlignment="Center" Spacing="40" HorizontalAlignment="Center">
                    <StackPanel Spacing="12" HorizontalAlignment="Center">
                        <TextBlock Text="{loc:Localize Onboarding_Java_Title}" FontSize="36" FontWeight="Black" Foreground="{DynamicResource PrimaryText}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{loc:Localize Onboarding_Java_Subtitle}" FontSize="16" Foreground="{DynamicResource SecondaryText}" HorizontalAlignment="Center" Opacity="0.8"/>
                    </StackPanel>
                    
                    <Border Background="{DynamicResource ContentBackground}" CornerRadius="16" Padding="40" Width="500">
                        <StackPanel Spacing="24">
                            <StackPanel Orientation="Horizontal" Spacing="16" HorizontalAlignment="Center">
                                <i:Icon x:Name="JavaStatusIcon" Value="fa-solid fa-check-circle" FontSize="48" Foreground="{DynamicResource SuccessBrush}"/>
                                <StackPanel Spacing="4" VerticalAlignment="Center">
                                    <TextBlock Text="{loc:Localize Onboarding_Java_Detected}" FontSize="20" FontWeight="Bold"/>
                                    <TextBlock x:Name="JavaVersionText" Text="Java 17.0.1" FontSize="14" Foreground="{DynamicResource SecondaryText}"/>
                                </StackPanel>
                            </StackPanel>
                            
                            <Button x:Name="BrowseJavaButton" Content="{loc:Localize Onboarding_Java_Browse}" Classes="Secondary" HorizontalAlignment="Stretch" Padding="0,12"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Step 4: Installation Creation (Placeholder) -->
            <Grid x:Name="Step4" IsVisible="False" Margin="60">
                <StackPanel VerticalAlignment="Center" Spacing="40" HorizontalAlignment="Center">
                    <StackPanel Spacing="12" HorizontalAlignment="Center">
                        <TextBlock Text="{loc:Localize Onboarding_Installation_Title}" FontSize="36" FontWeight="Black" Foreground="{DynamicResource PrimaryText}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{loc:Localize Onboarding_Installation_Subtitle}" FontSize="16" Foreground="{DynamicResource SecondaryText}" HorizontalAlignment="Center" Opacity="0.8"/>
                    </StackPanel>
                    
                    <Border Background="{DynamicResource ContentBackground}" CornerRadius="16" Padding="40" Width="600">
                        <StackPanel Spacing="24">
                            <StackPanel Spacing="12">
                                <TextBlock Text="{loc:Localize Onboarding_Installation_NameLabel}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource SecondaryText}" LetterSpacing="2"/>
                                <TextBox x:Name="InstallationNameBox" Text="My First Installation" Padding="16" CornerRadius="12"/>
                            </StackPanel>
                            
                            <StackPanel Spacing="12">
                                <TextBlock Text="{loc:Localize Onboarding_Installation_VersionLabel}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource SecondaryText}" LetterSpacing="2"/>
                                <ComboBox x:Name="VersionComboBox" HorizontalAlignment="Stretch" Padding="16" CornerRadius="12">
                                    <ComboBoxItem Content="Latest Release (1.21.1)" IsSelected="True"/>
                                    <ComboBoxItem Content="Latest Snapshot"/>
                                    <ComboBoxItem Content="Custom Version..."/>
                                </ComboBox>
                            </StackPanel>
                            
                            <StackPanel Spacing="12">
                                <TextBlock Text="{loc:Localize Onboarding_Installation_ModLoaderLabel}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource SecondaryText}" LetterSpacing="2"/>
                                <ComboBox x:Name="ModLoaderComboBox" HorizontalAlignment="Stretch" Padding="16" CornerRadius="12">
                                    <ComboBoxItem Content="None (Vanilla)" IsSelected="True"/>
                                    <ComboBoxItem Content="Fabric"/>
                                    <ComboBoxItem Content="Forge"/>
                                </ComboBox>
                            </StackPanel>
                            
                            <Button x:Name="CreateInstallationButton" Content="{loc:Localize Onboarding_Installation_Create}" Classes="Primary" HorizontalAlignment="Stretch" Padding="0,14" FontSize="16" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Step 5: Completion -->
            <Grid x:Name="Step5" IsVisible="False" Margin="60">
                <StackPanel VerticalAlignment="Center" Spacing="40" HorizontalAlignment="Center">
                    <i:Icon Value="fa-solid fa-check-circle" FontSize="120" Foreground="{DynamicResource SuccessBrush}" HorizontalAlignment="Center"/>
                    
                    <StackPanel Spacing="16" HorizontalAlignment="Center">
                        <TextBlock Text="{loc:Localize Onboarding_Complete_Title}" FontSize="48" FontWeight="Black" Foreground="{DynamicResource PrimaryText}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{loc:Localize Onboarding_Complete_Subtitle}" FontSize="18" Foreground="{DynamicResource SecondaryText}" HorizontalAlignment="Center" Opacity="0.8"/>
                    </StackPanel>
                    
                    <Border Background="{DynamicResource ContentBackground}" CornerRadius="16" Padding="32" Width="500">
                        <StackPanel Spacing="16">
                            <TextBlock Text="{loc:Localize Onboarding_Complete_QuickTips}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource SecondaryText}" LetterSpacing="2" HorizontalAlignment="Center"/>
                            
                            <StackPanel Spacing="12">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <i:Icon Value="fa-solid fa-gamepad" FontSize="18" Foreground="{DynamicResource SuccessBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{loc:Localize Onboarding_Complete_Tip1}" FontSize="14" Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <i:Icon Value="fa-solid fa-users" FontSize="18" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{loc:Localize Onboarding_Complete_Tip2}" FontSize="14" Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <i:Icon Value="fa-solid fa-puzzle-piece" FontSize="18" Foreground="{DynamicResource WarningBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{loc:Localize Onboarding_Complete_Tip3}" FontSize="14" Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <i:Icon Value="fa-solid fa-cog" FontSize="18" Foreground="{DynamicResource ErrorBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{loc:Localize Onboarding_Complete_Tip4}" FontSize="14" Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    
                    <Button x:Name="StartPlayingButton" Content="{loc:Localize Onboarding_Complete_StartPlaying}" Classes="Primary" Height="56" Width="300" FontSize="18" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
            </Panel>
        </ScrollViewer>

        <!-- Navigation Footer -->
        <Border Grid.Row="3" Background="{DynamicResource TitleBarBackground}" Padding="40,24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*,Auto">
                <Button Grid.Column="0" x:Name="BackButton" Content="{loc:Localize Onboarding_Back}" Classes="Secondary" Padding="20,10" IsVisible="False"/>
                <Button Grid.Column="1" x:Name="NextButton" Content="{loc:Localize Onboarding_Continue}" Classes="Primary" Padding="32,10"/>
            </Grid>
        </Border>
    </Grid>
</Window>
