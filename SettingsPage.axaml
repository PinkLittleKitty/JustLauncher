<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:res="clr-namespace:JustLauncher.Resources"
             xmlns:loc="clr-namespace:JustLauncher.Resources"
             x:Class="JustLauncher.SettingsPage"
             Background="Transparent">
    
    <UserControl.Styles>
        <Style Selector="Border.SettingsGroup">
            <Setter Property="Background" Value="{DynamicResource ContentBackground}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,5,0,20"/>
        </Style>
        <Style Selector="TextBlock.SettingsHeader">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style Selector="TextBlock.OptionTitle">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBlock.OptionDescription">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryText}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="*,Auto">
        <!-- Settings Content -->
        <ScrollViewer Grid.Row="0">
            <StackPanel Spacing="32" MaxWidth="800" HorizontalAlignment="Center" Margin="24,40,24,40">
                <TextBlock Text="{loc:Localize Key=Settings_Title}" Classes="PageHeader" HorizontalAlignment="Left" Margin="0,0,0,8"/>

                <!-- General Settings -->
                <StackPanel Spacing="12">
                    <TextBlock Text="{loc:Localize Key=Settings_General}" Classes="SettingsHeader"/>
                    <Border Classes="Card" Padding="24">
                        <StackPanel Spacing="20">
                            <!-- Theme -->
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{loc:Localize Key=Settings_Theme}" Classes="OptionTitle"/>
                                    <TextBlock Text="{loc:Localize Key=Settings_ThemeDescription}" Classes="OptionDescription"/>
                                </StackPanel>
                                <ComboBox Grid.Column="1" x:Name="ThemeComboBox" MinWidth="150" SelectionChanged="OnThemeChanged">
                                    <ComboBoxItem Content="{loc:Localize Key=Common_SystemDefault}"/>
                                    <ComboBoxItem Content="{loc:Localize Key=Common_Light}"/>
                                    <ComboBoxItem Content="{loc:Localize Key=Common_Dark}"/>
                                </ComboBox>
                            </Grid>
                            
                            <Separator Height="1" Background="{DynamicResource BorderBrush}"/>
                            
                            <!-- Language -->
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{loc:Localize Key=Settings_Language}" Classes="OptionTitle"/>
                                    <TextBlock Text="{loc:Localize Key=Settings_LanguageDescription}" Classes="OptionDescription"/>
                                </StackPanel>
                                <ComboBox Grid.Column="1" x:Name="LanguageComboBox" MinWidth="150" SelectionChanged="OnLanguageChanged"/>
                            </Grid>
                            
                            <Separator Height="1" Background="{DynamicResource BorderBrush}"/>
                            
                            <!-- Close on Launch -->
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{loc:Localize Key=Settings_CloseOnLaunch}" Classes="OptionTitle"/>
                                    <TextBlock Text="{loc:Localize Key=Settings_CloseOnLaunchDescription}" Classes="OptionDescription"/>
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1" x:Name="CloseOnLaunchToggle" OnContent="{loc:Localize Key=Common_On}" OffContent="{loc:Localize Key=Common_Off}"/>
                            </Grid>

                            <Separator Height="1" Background="{DynamicResource BorderBrush}"/>
                            
                            <!-- Saki Toggle -->
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{loc:Localize Key=Settings_SakiMode}" Classes="OptionTitle"/>
                                    <TextBlock Text="{loc:Localize Key=Settings_SakiModeDescription}" Classes="OptionDescription"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                                    <TextBox x:Name="SakiSkinTextBox" Width="120" Watermark="Skin Name" VerticalAlignment="Center"/>
                                    <ToggleSwitch x:Name="SakiToggle" OnContent="{loc:Localize Key=Common_On}" OffContent="{loc:Localize Key=Common_Off}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
                
                <!-- Application Updates -->
                <StackPanel Spacing="12">
                    <TextBlock Text="{loc:Localize Key=Update_CheckNow}" Classes="SettingsHeader"/>
                    <Border Classes="Card" Padding="24">
                        <StackPanel Spacing="20">
                            <!-- Check on Startup -->
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{loc:Localize Key=Update_CheckOnStartup}" Classes="OptionTitle"/>
                                    <TextBlock Text="{loc:Localize Key=Update_CheckOnStartupDescription}" Classes="OptionDescription"/>
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1" x:Name="CheckUpdatesToggle" OnContent="{loc:Localize Key=Common_On}" OffContent="{loc:Localize Key=Common_Off}"/>
                            </Grid>
                            
                            <Separator Height="1" Background="{DynamicResource BorderBrush}"/>
                            
                            <!-- Check Now Button & Last Checked -->
                            <Grid ColumnDefinitions="*,Auto">
                                 <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock x:Name="LastCheckedText" Text="{loc:Localize Key=Update_LastChecked}" Classes="OptionDescription"/>
                                 </StackPanel>
                                 <Button Grid.Column="1" x:Name="CheckUpdatesButton" Content="{loc:Localize Key=Update_CheckNow}" Classes="Primary"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Java Settings -->
                <StackPanel Spacing="12">
                    <TextBlock Text="{loc:Localize Key=Settings_JavaMemory}" Classes="SettingsHeader"/>
                    <Border Classes="Card" Padding="24">
                        <StackPanel Spacing="20">
                            <!-- Java Version Selector -->
                            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Text="{loc:Localize Key=Settings_JavaExecutablePath}" Classes="OptionTitle"/>
                                    <TextBlock Text="{loc:Localize Key=Settings_JavaExecutablePathDescription}" Classes="OptionDescription"/>
                                </StackPanel>
                                
                                <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,10,0,0" ColumnDefinitions="*,Auto">
                                    <ComboBox x:Name="JavaVersionComboBox" HorizontalAlignment="Stretch" Margin="0,0,10,0" PlaceholderText="Select Java Version..."/>
                                    <Button Grid.Column="1" x:Name="BrowseJavaButton" Content="{loc:Localize Key=Common_Browse}..." Classes="Secondary"/>
                                </Grid>
                            </Grid>

                            <Separator Height="1" Background="{DynamicResource BorderBrush}"/>

                            <!-- Memory -->
                            <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{loc:Localize Key=Settings_MemoryAllocation}" Classes="OptionTitle"/>
                                        <TextBlock Text="{loc:Localize Key=Settings_MemoryAllocationDescription}" Classes="OptionDescription"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" x:Name="MemoryValueText" Text="2 GB" Classes="OptionTitle" Foreground="{DynamicResource AccentBrush}"/>
                                </Grid>
                                
                                <!-- Presets -->
                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,5">
                                    <Button x:Name="MemLowBtn" Content="Low (2GB)" Classes="Secondary" FontSize="11" Padding="8,4" CornerRadius="12"/>
                                    <Button x:Name="MemMedBtn" Content="Med (4GB)" Classes="Secondary" FontSize="11" Padding="8,4" CornerRadius="12"/>
                                    <Button x:Name="MemHighBtn" Content="High (8GB)" Classes="Secondary" FontSize="11" Padding="8,4" CornerRadius="12"/>
                                </StackPanel>
                                
                                <Slider x:Name="MemorySlider" Minimum="1" Maximum="32" TickFrequency="1" IsSnapToTickEnabled="True"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Game Settings -->
                <StackPanel Spacing="12">
                    <TextBlock Text="{loc:Localize Key=Settings_GameConfiguration}" Classes="SettingsHeader"/>
                    <Border Classes="Card" Padding="24">
                        <StackPanel Spacing="20">
                            <!-- Separate Directory -->
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                                    <TextBlock Text="{loc:Localize Key=Settings_IsolateGameInstances}" Classes="OptionTitle"/>
                                    <TextBlock Text="{loc:Localize Key=Settings_IsolateGameInstancesDescription}" Classes="OptionDescription" TextWrapping="Wrap"/>
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1" x:Name="UseSeparateGameDirToggle" OnContent="{loc:Localize Key=Common_On}" OffContent="{loc:Localize Key=Common_Off}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Sticky Action Bar -->
        <Border Grid.Row="1" Background="{DynamicResource TitleBarBackground}" 
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="24,16">
            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                <Button x:Name="SaveButton" Content="{loc:Localize Key=Settings_SaveChanges}" 
                        Classes="Primary" Padding="32,12"
                        Cursor="Hand">
                    <Button.Transitions>
                        <Transitions>
                            <DoubleTransition Property="Opacity" Duration="0:0:0.2"/>
                        </Transitions>
                    </Button.Transitions>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
