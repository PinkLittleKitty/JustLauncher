<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:JustLauncher"
             xmlns:converters="clr-namespace:JustLauncher.Converters"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             xmlns:controls="clr-namespace:JustLauncher.Controls"
             x:Class="JustLauncher.AccountsPage"
             Background="Transparent">
    
    <UserControl.Resources>
        <converters:AccountTypeToIconConverter x:Key="AccountTypeToIconConverter"/>
        <converters:SkinToBitmapConverter x:Key="SkinToBitmapConverter"/>
    </UserControl.Resources>

    <Grid Margin="40" RowDefinitions="Auto,*,Auto">
        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,40">
            <StackPanel Grid.Column="0">
                <TextBlock Text="ACCOUNTS" Classes="PageHeader"/>
                <TextBlock Text="Manage your player profiles" Classes="PageDescription"/>
            </StackPanel>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <Button x:Name="RefreshButton" ToolTip.Tip="Refresh" Padding="12" Classes="Secondary">
                    <i:Icon Value="fa-solid fa-sync"/>
                </Button>
                <Button x:Name="AddAccountButton" Classes="Primary" Padding="20,12">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <i:Icon Value="fa-solid fa-plus"/>
                        <TextBlock Text="ADD ACCOUNT"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Accounts Grid -->
        <ScrollViewer Grid.Row="1">
            <ItemsControl x:Name="AccountsPanel">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Classes="Card" Margin="0,0,24,24" Padding="20" Width="260">
                            <StackPanel Spacing="20">
                                <!-- Avatar & Status -->
                                <Grid HorizontalAlignment="Center">
                                    <Border Width="96" Height="96" CornerRadius="0" ClipToBounds="True" 
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="3">
                                        <Panel>
                                            <controls:AsyncImage SourceUrl="{Binding Username, StringFormat='https://minotar.net/avatar/{0}/64'}"
                                                   Stretch="UniformToFill"
                                                   RenderOptions.BitmapInterpolationMode="None"/>
                                            <!-- Overlay for active status -->
                                            <Border IsVisible="{Binding IsActive}" 
                                                    Background="{DynamicResource SuccessBrush}" Opacity="0.1"/>
                                        </Panel>
                                    </Border>
                                    
                                    <Border IsVisible="{Binding IsActive}"
                                            Background="{DynamicResource SuccessBrush}" CornerRadius="10" Padding="8,4"
                                            VerticalAlignment="Top" HorizontalAlignment="Right"
                                            Margin="0,-5,-5,0" Effect="drop-shadow(0 2 4 #40000000)">
                                        <TextBlock Text="ACTIVE" FontSize="10" FontWeight="Black" Foreground="White"/>
                                    </Border>
                                </Grid>

                                <!-- Info -->
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding Username}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource PrimaryText}" 
                                               HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding AccountType}" FontSize="12" Foreground="{DynamicResource SecondaryText}" 
                                               HorizontalAlignment="Center" FontWeight="SemiBold" Opacity="0.8"/>
                                </StackPanel>

                                <!-- Actions -->
                                <StackPanel Spacing="12">
                                    <Button x:Name="UseAccountButton" Tag="{Binding}" 
                                            Classes="Primary"
                                            IsVisible="{Binding !IsActive}"
                                            HorizontalAlignment="Stretch" Padding="0,10">
                                         <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                            <i:Icon Value="fa-solid fa-check"/>
                                            <TextBlock Text="USE ACCOUNT"/>
                                        </StackPanel>   
                                    </Button>
                                    
                                    <Grid ColumnDefinitions="*,12,*">
                                        <Button Grid.Column="0" x:Name="EditAccountButton" Tag="{Binding}" Classes="Secondary" HorizontalAlignment="Stretch">
                                            <i:Icon Value="fa-solid fa-pen"/>
                                        </Button>
                                        <Button Grid.Column="2" x:Name="DeleteAccountButton" Tag="{Binding}" Classes="Danger" HorizontalAlignment="Stretch">
                                            <i:Icon Value="fa-solid fa-trash"/>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="2" Padding="0,20,0,0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <TextBlock x:Name="AccountCountText" Text="0 Accounts Connected" Foreground="{DynamicResource SecondaryText}" FontSize="12"/>
        </Border>
    </Grid>
</UserControl>
