<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="JustLauncher.SettingsPage"
             Background="Transparent">
    
    <UserControl.Styles>
        <Style Selector="Border.SettingsGroup">
            <Setter Property="Background" Value="{DynamicResource ContentBackground}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,5,0,20"/>
        </Style>
        <Style Selector="TextBlock.SettingsHeader">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style Selector="TextBlock.OptionTitle">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBlock.OptionDescription">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryText}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
        <StackPanel Spacing="20" MaxWidth="800" HorizontalAlignment="Left" Margin="30,30,30,80">
            <TextBlock Text="Settings" FontSize="28" Foreground="{DynamicResource PrimaryText}" FontWeight="Bold" Margin="0,0,0,10"/>

            <!-- General Settings -->
            <StackPanel>
                <TextBlock Text="General" Classes="SettingsHeader"/>
                <Border Classes="SettingsGroup">
                    <StackPanel Spacing="20">
                        <!-- Theme -->
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Theme" Classes="OptionTitle"/>
                                <TextBlock Text="Select the application appearance" Classes="OptionDescription"/>
                            </StackPanel>
                            <ComboBox Grid.Column="1" x:Name="ThemeComboBox" MinWidth="150">
                                <ComboBoxItem Content="System Default"/>
                                <ComboBoxItem Content="Light"/>
                                <ComboBoxItem Content="Dark"/>
                            </ComboBox>
                        </Grid>
                        
                        <!-- Close on Launch -->
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Close Launcher on Start" Classes="OptionTitle"/>
                                <TextBlock Text="Minimize or close the launcher when the game starts" Classes="OptionDescription"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" x:Name="CloseOnLaunchToggle" OnContent="On" OffContent="Off"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Java Settings -->
            <StackPanel>
                <TextBlock Text="Java &amp; Memory" Classes="SettingsHeader"/>
                <Border Classes="SettingsGroup">
                    <StackPanel Spacing="20">
                        <!-- Java Path -->
                        <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Java Executable Path" Classes="OptionTitle"/>
                                <TextBlock Text="Leave empty to use auto-detected Java" Classes="OptionDescription"/>
                            </StackPanel>
                            <Button x:Name="BrowseJavaButton" Grid.Row="0" Grid.Column="1" Content="Browse..." Classes="Secondary"/>
                            <TextBox x:Name="JavaPathTextBox" Grid.Row="1" Grid.ColumnSpan="2" Margin="0,10,0,0" Watermark="Auto-detected"/>
                        </Grid>

                        <Separator Height="1" Background="{DynamicResource BorderBrush}"/>

                        <!-- Memory -->
                        <StackPanel Spacing="10">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Memory Allocation" Classes="OptionTitle"/>
                                    <TextBlock Text="Maximum RAM for Minecraft" Classes="OptionDescription"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" x:Name="MemoryValueText" Text="2 GB" Classes="OptionTitle" Foreground="{DynamicResource AccentBrush}"/>
                            </Grid>
                            <Slider x:Name="MemorySlider" Minimum="1" Maximum="32" TickFrequency="1" IsSnapToTickEnabled="True"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Game Settings -->
            <StackPanel>
                <TextBlock Text="Game Configuration" Classes="SettingsHeader"/>
                <Border Classes="SettingsGroup">
                    <StackPanel Spacing="20">
                        <!-- Separate Directory -->
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Margin="0,0,20,0">
                                <TextBlock Text="Isolate Game Instances" Classes="OptionTitle"/>
                                <TextBlock Text="Use separate folders for each installation (Recommended for modpacks)" Classes="OptionDescription" TextWrapping="Wrap"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" x:Name="UseSeparateGameDirToggle" OnContent="On" OffContent="Off"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Actions -->
            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button x:Name="SaveButton" Content="Save Changes" Classes="Primary" Padding="20,10"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
