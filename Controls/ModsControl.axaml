<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             xmlns:loc="clr-namespace:JustLauncher.Resources"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="JustLauncher.Controls.ModsControl">
    <Grid RowDefinitions="Auto,*">
        <TabControl Grid.RowSpan="2">
            <TabItem Header="{loc:Localize Key=Mods_Installed}">
                <Grid RowDefinitions="Auto,*">
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="0,10,0,10">
                        <Button x:Name="AddModButton" Classes="Primary" Content="{loc:Localize Key=Common_Add}"/>
                        <Button x:Name="OpenModsFolderButton" Classes="Secondary" Content="Open Folder"/>
                        <Button x:Name="RefreshModsButton" Classes="Secondary" Content="Refresh"/>
                        <Button x:Name="CheckUpdatesButton" Classes="Secondary" Content="{loc:Localize Key=Update_CheckNow}" CommandParameter="{Binding}"/>
                    </StackPanel>
                    <ListBox Grid.Row="1" x:Name="ModsListBox" Background="Transparent" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource WindowBackground}" CornerRadius="8" Padding="10" Margin="0,0,0,5">
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <CheckBox IsChecked="{Binding IsEnabled}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                                <Border CornerRadius="4" Background="{DynamicResource AccentBrush}" Padding="4,1" IsVisible="{Binding UpdateAvailable}">
                                                    <TextBlock Text="UPDATE" FontSize="10" Foreground="White" FontWeight="Bold"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Description}" FontSize="11" Foreground="{DynamicResource SecondaryText}" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding RemoteVersion, StringFormat='New version: {0}'}" FontSize="10" Foreground="{DynamicResource SuccessBrush}" IsVisible="{Binding UpdateAvailable}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="5" MinWidth="80">
                                            <TextBlock Text="{Binding Version}" HorizontalAlignment="Right" Foreground="{DynamicResource SecondaryText}" FontSize="12"/>
                                            <Button Content="{loc:Localize Key=Mods_Update}" Classes="Primary" FontSize="11" Padding="8,2" 
                                                    HorizontalAlignment="Stretch" IsVisible="{Binding UpdateAvailable}" Tag="{Binding}" x:Name="UpdateSingleButton"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>
            <TabItem Header="{loc:Localize Key=Mods_Browse}">
                <Grid RowDefinitions="Auto,*">
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,10,0,10">
                        <TextBox x:Name="SearchBox" Watermark="{loc:Localize Key=Mods_SearchPlaceholder}" Margin="0,0,10,0"/>
                        <Button Grid.Column="1" x:Name="SearchButton" Classes="Primary" Content="Search"/>
                    </Grid>
                    <ScrollViewer Grid.Row="1">
                        <StackPanel>
                            <ListBox x:Name="BrowseListBox" Background="Transparent" BorderThickness="0" Padding="0,0,0,10" ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource WindowBackground}" CornerRadius="8" Padding="10" Margin="0,0,0,5">
                                            <Grid ColumnDefinitions="Auto,*,Auto">
                                                <Border Grid.Column="0" Width="40" Height="40" CornerRadius="4" ClipToBounds="True" Margin="0,0,10,0">
                                                    <Image Source="{Binding IconPath, Converter={StaticResource AsyncImageConverter}, ConverterParameter={Binding}}"/>
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                                    <TextBlock Text="{Binding Authors}" FontSize="11" Foreground="{DynamicResource SecondaryText}"/>
                                                </StackPanel>
                                                <Panel Grid.Column="2" VerticalAlignment="Center" MinWidth="100">
                                                    <Button x:Name="DownloadButton" Content="{loc:Localize Key=Mods_Download}" 
                                                            Classes="Primary" HorizontalAlignment="Stretch" Tag="{Binding}" IsVisible="{Binding !IsInstalled}"/>
                                                    
                                                    <Button x:Name="UpdateBrowseButton" Content="{loc:Localize Key=Mods_Update}" 
                                                            Classes="Success" HorizontalAlignment="Stretch" Tag="{Binding}" IsVisible="{Binding UpdateAvailable}"/>

                                                    <StackPanel IsVisible="{Binding IsDownloading}" Spacing="5">
                                                        <TextBlock Text="{loc:Localize Key=Mods_Downloading}" FontSize="10" HorizontalAlignment="Center"/>
                                                        <ProgressBar Minimum="0" Maximum="100" Value="{Binding DownloadProgress}" Height="4"/>
                                                    </StackPanel>

                                                    <TextBlock Text="{loc:Localize Key=Mods_AlreadyInstalled}" 
                                                               IsVisible="{Binding IsInstalled}" 
                                                               VerticalAlignment="Center" HorizontalAlignment="Center"
                                                               Foreground="{DynamicResource SuccessBrush}" FontWeight="Bold"/>
                                                </Panel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <Button x:Name="LoadMoreButton" Classes="Secondary" Content="Load More" 
                                    HorizontalAlignment="Stretch" Margin="0,5,0,10" IsVisible="False"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
